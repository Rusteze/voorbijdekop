{
  "name": "voorbijdekop-root",
  "private": true,
  "type": "module",
  "scripts": {
    "build:data": "tsx scripts/build-data.ts",
    "quiz:import-swow": "tsx scripts/import-swow.ts",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm run build:data && npm --prefix web run build",
