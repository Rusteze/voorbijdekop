    "build": "npm run build:web"
  },
  "devDependencies": {
    "@types/node": "^18.19.87",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.2.5",
    "openai": "^4.86.2"
  }
}
